{
  "_version": "1.26.0",
  "sap.app": {
    "id": "apmgtnsp.workflowuimodule",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.8.4",
      "toolsId": "1cec9640-0cd2-48f0-b118-00f44b5cbc14"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "config": {
      "dmsApiUrl": "https://sbpa_helper.cfapps.ap10.hana.ondemand.com/api/Dms/get-folder-items?folderId={FOLDER_ID}",
      "tokenApiUrl": "https://sbpa_helper.cfapps.ap10.hana.ondemand.com/api/token"
    },
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.82.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.suite.ui.generic.template": {},
        "sap.ui.comp": {},
        "sap.ui.generic.app": {},
        "sap.ui.table": {},
        "sap.ushell": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "apmgtnsp.workflowuimodule.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "https://sbpa_helper.cfapps.ap10.hana.ondemand.com/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "apmgtnsp.workflowuimodule.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteorderApprovalForm",
          "pattern": ":?query:",
          "target": [
            "TargetorderApprovalForm"
          ]
        }
      ],
      "targets": {
        "TargetorderApprovalForm": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "orderApprovalForm",
          "viewName": "orderApprovalForm"
        }
      }
    },
    "rootView": {
      "viewName": "apmgtnsp.workflowuimodule.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "apsmanagement"
  },
  "sap.bpa.task": {
    "_version": "1.0.0",
    "outcomes": [
      {
        "id": "approve",
        "label": "Approve"
      },
      {
        "id": "reject",
        "label": "Reject"
      }
    ],
    "inputs": {
      "$schema": "http://json-schema.org/draft-07/schema",
      "title": "input",
      "type": "object",
      "required": [],
      "properties": {

        "RequestNo":        { "type": "string",  "title": "Request No"        },
        "WorkflowType":     { "type": "string",  "title": "Workflow Type"     },
        "WorkflowDesc":     { "type": "string",  "title": "Workflow Desc"     },
        "TransactionDesc":  { "type": "string",  "title": "Transaction Desc"  },
        "RequestStatus":    { "type": "string",  "title": "Request Status"    },
        "SubmitDateTime":   { "type": "string",  "title": "Submit Date Time"  },

        "Requester":        { "type": "string",  "title": "Requester"         },
        "ReviewerEmpID":    { "type": "string",  "title": "Reviewer Emp ID"   },
        "Approver":         { "type": "string",  "title": "Approver"          },
        "ApproverComment":  { "type": "string",  "title": "Approver Comment"  },

        "FolderID":         { "type": "string",  "title": "Folder ID"         },
        "PreviewFolderID":  { "type": "string",  "title": "Preview Folder ID" },

        "IsAllApproved":    { "type": "boolean", "title": "Is All Approved"   },
        "IsReject":         { "type": "boolean", "title": "Is Reject"         },
        "IsClose":          { "type": "boolean", "title": "Is Close"          },
        "IsTestMode":         { "type": "boolean", "title": "Test Mode"       },

        "CreatedBy":        { "type": "string", "title": "Created By"         },
        "CreatedPosition":  { "type": "string", "title": "Created Position"   },
        "CreatedDate":      { "type": "string", "title": "Created Date"       },

        "Approver1Name":     { "type": "string", "title": "Approver 1 Name"     },
        "Approver1Position": { "type": "string", "title": "Approver 1 Position" },
        "Approver1Date":     { "type": "string", "title": "Approver 1 Date"     },
        "Approver1Comment":  { "type": "string", "title": "Approver 1 Comment"  },

        "Approver2Name":     { "type": "string", "title": "Approver 2 Name"     },
        "Approver2Position": { "type": "string", "title": "Approver 2 Position" },
        "Approver2Date":     { "type": "string", "title": "Approver 2 Date"     },
        "Approver2Comment":  { "type": "string", "title": "Approver 2 Comment"  },

        "Approver3Name":     { "type": "string", "title": "Approver 3 Name"     },
        "Approver3Position": { "type": "string", "title": "Approver 3 Position" },
        "Approver3Date":     { "type": "string", "title": "Approver 3 Date"     },
        "Approver3Comment":  { "type": "string", "title": "Approver 3 Comment"  },

        "Approver4Name":     { "type": "string", "title": "Approver 4 Name"     },
        "Approver4Position": { "type": "string", "title": "Approver 4 Position" },
        "Approver4Date":     { "type": "string", "title": "Approver 4 Date"     },
        "Approver4Comment":  { "type": "string", "title": "Approver 4 Comment"  },

        "Approver5Name":     { "type": "string", "title": "Approver 5 Name"     },
        "Approver5Position": { "type": "string", "title": "Approver 5 Position" },
        "Approver5Date":     { "type": "string", "title": "Approver 5 Date"     },
        "Approver5Comment":  { "type": "string", "title": "Approver 5 Comment"  },

        "Approver6Name":     { "type": "string", "title": "Approver 6 Name"     },
        "Approver6Position": { "type": "string", "title": "Approver 6 Position" },
        "Approver6Date":     { "type": "string", "title": "Approver 6 Date"     },
        "Approver6Comment":  { "type": "string", "title": "Approver 6 Comment"  },

        "Approver7Name":     { "type": "string", "title": "Approver 7 Name"     },
        "Approver7Position": { "type": "string", "title": "Approver 7 Position" },
        "Approver7Date":     { "type": "string", "title": "Approver 7 Date"     },
        "Approver7Comment":  { "type": "string", "title": "Approver 7 Comment"  },

        "Approver8Name":     { "type": "string", "title": "Approver 8 Name"     },
        "Approver8Position": { "type": "string", "title": "Approver 8 Position" },
        "Approver8Date":     { "type": "string", "title": "Approver 8 Date"     },
        "Approver8Comment":  { "type": "string", "title": "Approver 8 Comment"  },

        "Approver9Name":     { "type": "string", "title": "Approver 9 Name"     },
        "Approver9Position": { "type": "string", "title": "Approver 9 Position" },
        "Approver9Date":     { "type": "string", "title": "Approver 9 Date"     },
        "Approver9Comment":  { "type": "string", "title": "Approver 9 Comment"  },

        "Approver10Name":     { "type": "string", "title": "Approver 10 Name"     },
        "Approver10Position": { "type": "string", "title": "Approver 10 Position" },
        "Approver10Date":     { "type": "string", "title": "Approver 10 Date"     },
        "Approver10Comment":  { "type": "string", "title": "Approver 10 Comment"  }
      }
    },
    "outputs": {
      "$schema": "http://json-schema.org/draft-07/schema",
      "title": "output",
      "type": "object",
      "required": [
        "ApproverComment",
        "SignatureUsername",
        "SignaturePassword",
        "SignatureToken"
      ],
      "properties": {
        "ApproverComment": {
          "type": "string",
          "title": "Approver Comment"
        },
        "SignatureUsername": {
          "type": "string",
          "title": "Signature Username"
        },
        "SignaturePassword": {
          "type": "string",
          "title": "Signature Password"
        },
        "SignatureToken": {
          "type": "string",
          "title": "Signature Token"
        }
      }
    },
    "category": "approval"
  }
}
